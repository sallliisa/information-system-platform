{
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "vue3-google-map": ["./node_modules/vue3-google-map/dist/types/index.d.ts"]
    },
    "target": "es2017",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "lib": ["dom", "es2022"],
    "verbatimModuleSyntax": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "vueCompilerOptions": {
    "strictTemplates": false
  }
}
