{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@client/data-model/*": [
        "../../packages/data-model/src/*"
      ],
      "@repo/model-meta": [
        "../../packages/model-meta/src/index.ts"
      ],
      "@repo/model-meta/*": [
        "../../packages/model-meta/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
