{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@repo/model-meta": [
        "../../packages/model-meta/src/index.ts"
      ],
      "@repo/model-meta/*": [
        "../../packages/model-meta/src/*"
      ],
      "@repo/sdk": [
        "../../packages/sdk/src/index.ts"
      ],
      "@repo/sdk/*": [
        "../../packages/sdk/src/*"
      ],
      "@repo/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@repo/domain/*": [
        "../../packages/domain/src/*"
      ]
    }
  },
  "include": [
    "app/**/*",
    "src/**/*",
    "../../packages/domain/src/**/*",
    "expo-env.d.ts",
    "../../packages/model-meta/src/**/*",
    "../../packages/sdk/src/**/*",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts"
  ],
  "exclude": [
    "../../packages/sdk/src/__tests__/*",
    "../../packages/model-meta/src/__tests__/*"
  ]
}
