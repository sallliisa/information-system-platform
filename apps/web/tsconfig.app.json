{
  "extends": "../../tsconfig.base.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "../../packages/model-meta/src/**/*",
    "../../packages/sdk/src/**/*",
    "../../packages/vue-framework/src/**/*",
    "../../packages/apostle/src/**/*"
  ],
  "exclude": [
    "src/**/__tests__/*",
    "../../packages/sdk/src/__tests__/*",
    "../../packages/model-meta/src/__tests__/*",
    "../../packages/vue-framework/src/**/__tests__/*",
    "../../packages/apostle/src/**/__tests__/*"
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@repo/model-meta": [
        "../../packages/model-meta/src/index.ts"
      ],
      "@repo/model-meta/*": [
        "../../packages/model-meta/src/*"
      ],
      "@repo/sdk": [
        "../../packages/sdk/src/index.ts"
      ],
      "@repo/sdk/*": [
        "../../packages/sdk/src/*"
      ],
      "vue3-google-map": [
        "./node_modules/vue3-google-map/dist/types/index.d.ts"
      ],
      "@repo/vue-framework": [
        "../../packages/vue-framework/src/index.ts"
      ],
      "@repo/vue-framework/*": [
        "../../packages/vue-framework/src/*"
      ],
      "@repo/apostle": [
        "../../packages/apostle/src/index.ts"
      ],
      "@repo/apostle/*": [
        "../../packages/apostle/src/*"
      ]
    },
    "module": "esnext",
    "target": "es2017"
  },
  "vueCompilerOptions": {
    "strictTemplates": false
  }
}
